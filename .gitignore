# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/test-results.json
/playwright-report/
/test-reports/
/.playwright-browsers/

# runtime logs
stderr.log
stdout.log

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
Thumbs.db
desktop.ini
*.pem

# IDE
.vscode/
.idea/
*.swp
*.swo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tsc output logs
tsc-output*.txt
tsc-errors*.txt
rescan-tsc.txt

# Electron build output
/release/

# Electron TS compiled output
/electron/dist/

# Electron build temp files
.electron-build-disabled
.api-routes-backup
.dynamic-routes-backup
app_asar_del_*

# Buyer/commercial docs
README_FOR_BUYER.md

# Backup archives
*.zip
ai-animation-studio-*.zip

# Large binary documents
*.docx

# AI context files
.ai/

# Obsolete docs
docs/废弃/

# Historical doc snapshots (keep only latest)
docs/project-docs-2025*/

# Trae IDE
.trae/
