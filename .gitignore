# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/test-results.json
/playwright-report/
/test-reports/
/.playwright-browsers/
/.stryker-tmp/

# runtime logs
stderr.log
stdout.log

# vite
/out/

# Next.js (legacy, migrated to Vite)
.next/

# production
/build

# misc
.DS_Store
Thumbs.db
desktop.ini
*.pem
test-debug.cjs

# IDE
.vscode/
.idea/
*.swp
*.swo

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel (legacy)
.vercel

# typescript
*.tsbuildinfo

# tsc output logs
tsc-output*.txt
tsc-errors*.txt
rescan-tsc.txt

# Electron build output
/release/

# Electron TS compiled output
/electron/dist/

# shared-logic 编译产物（由 build:shared-logic 在构建时生成，不入库）
src/shared-logic/**/*.js

# Electron build temp files
.electron-build-disabled
.api-routes-backup
.dynamic-routes-backup
app_asar_del_*

# Backup archives
*.zip
ai-animation-studio-*.zip

# Large binary documents
*.docx

# AI context files (maintenance guides for AI-driven development)
# .ai/

# Obsolete docs
docs/废弃/

# Historical doc snapshots (keep only latest)
docs/project-docs-2025*/

# Trae IDE (project rules are version-controlled for AI maintenance)
# .trae/

# Build artifacts (v0.12.1+)
release2/

# Buyer-facing document (not for open-source release)
README_FOR_BUYER.md

# Contest submission materials (报名贴、初赛贴、创意提案 — 大赛专属，不入公开仓库)
docs/contest/
