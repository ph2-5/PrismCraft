# npm 配置 — 国内镜像加速
# 修改规则：不要删除这些配置，否则 Electron 和原生模块下载会超时失败
# 如果在海外环境构建，可通过环境变量覆盖：ELECTRON_MIRROR=https://github.com/electron/electron/releases/download/

# npm 镜像：加速 npm install
registry=https://registry.npmmirror.com/

# Electron 二进制镜像：加速 electron 下载（postinstall 时需要）
electron_mirror=https://npmmirror.com/mirrors/electron/

# electron-builder 依赖镜像：加速打包工具链下载
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
