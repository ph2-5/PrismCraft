{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": true,
    "moduleResolution": "bundler",
    "allowJs": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@domain/*": ["./src/domain/*"]
      // 注意：@shared-logic/* 未通过 tsconfig paths 配置，因为 "../src/shared-logic/*"
      // 在 rootDir "./src" 之外，会触发 TS6059 错误。
      // 类型解析依赖 scripts/setup-shared-logic-symlink.mjs 创建的
      // node_modules/@shared-logic junction（指向 src/shared-logic）。
      // 运行时解析依赖 electron/src/shared-logic-resolve.ts 的 Module._resolveFilename hack。
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "after-sign.js",
    "code-sign-config.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**/*",
    "**/test-helpers/**/*",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
