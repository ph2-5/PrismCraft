{
  "id": "openai",
  "name": "OpenAI",
  "format": "openai",
  "baseUrl": "https://api.openai.com/v1",
  "detection": {
    "rules": [
      {
        "pattern": "^sk-proj-[a-zA-Z0-9_-]+$",
        "confidence": "high"
      },
      {
        "pattern": "^sk-[a-zA-Z0-9]{48}$",
        "confidence": "high",
        "checkId": "openai_exclude_or_proj_ant"
      }
    ],
    "suggestedName": "OpenAI",
    "baseUrl": "https://api.openai.com/v1"
  },
  "models": [
    {
      "id": "gpt-4o",
      "name": "GPT-4o",
      "capabilities": [
        "text",
        "vision"
      ],
      "defaultParams": {
        "maxTokens": 4096,
        "temperature": 0.7
      },
      "verifiedAt": "2026-07-23"
    },
    {
      "id": "gpt-4o-mini",
      "name": "GPT-4o Mini",
      "capabilities": [
        "text",
        "vision"
      ],
      "defaultParams": {
        "maxTokens": 4096,
        "temperature": 0.7
      },
      "verifiedAt": "2026-07-23"
    },
    {
      "id": "gpt-4-turbo",
      "name": "GPT-4 Turbo",
      "capabilities": [
        "text",
        "vision"
      ],
      "defaultParams": {
        "maxTokens": 4096,
        "temperature": 0.7
      },
      "verifiedAt": "2026-07-23",
      "deprecated": true,
      "deprecatedReason": "已被 GPT-4o 和 GPT-5 系列替代，建议升级"
    },
    {
      "id": "gpt-3.5-turbo",
      "name": "GPT-3.5 Turbo",
      "capabilities": [
        "text"
      ],
      "defaultParams": {
        "maxTokens": 4096,
        "temperature": 0.7
      },
      "verifiedAt": "2026-07-23",
      "deprecated": true,
      "deprecatedReason": "老一代模型，建议升级到 GPT-4o-mini 或 GPT-5 系列"
    },
    {
      "id": "dall-e-3",
      "name": "DALL-E 3",
      "capabilities": [
        "image"
      ],
      "defaultParams": {
        "size": "1024x1024",
        "quality": "standard"
      },
      "modelCapabilities": {
        "maxReferences": 1,
        "maxResolution": 1024,
        "maxSizeMB": 5,
        "supportsLastFrame": false,
        "referenceMode": "merged",
        "providerId": "openai-compatible",
        "defaultImageSize": "1024x1024",
        "supportedImageSizes": [
          {
            "width": 1024,
            "height": 1024,
            "label": "1:1",
            "aspectRatio": "1:1"
          },
          {
            "width": 1024,
            "height": 1792,
            "label": "2:3",
            "aspectRatio": "2:3"
          },
          {
            "width": 1792,
            "height": 1024,
            "label": "3:2",
            "aspectRatio": "3:2"
          }
        ],
        "supportsCharacterRef": false,
        "supportsSceneRef": false
      },
      "verifiedAt": "2026-07-23"
    },
    {
      "id": "dall-e-2",
      "name": "DALL-E 2",
      "capabilities": [
        "image"
      ],
      "defaultParams": {
        "size": "1024x1024"
      },
      "verifiedAt": "2026-07-23",
      "deprecated": true,
      "deprecatedReason": "2026-05-12 从 API 移除，已被 DALL-E 3 替代"
    }
  ]
}
