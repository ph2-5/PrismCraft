{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shared-logic/*": [
        "./src/shared-logic/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "dist/types/**/*.ts",
    "dist/dev/types/**/*.ts",
    "out/types/**/*.ts",
    "out/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "_backup-v2",
    "release",
    "next.config.ts",
    "next.config.mjs",
    "electron",
    "src/__tests__",
    "**/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/test-helpers",
    "tests",
    "playwright-report",
    "test-results",
    "test-reports",
    "scripts/test-config",
    "scripts/video-test-tool",
    "vitest.config.ts",
    "vitest.config.test-shot.ts",
    "vitest.coverage.config.ts",
    "playwright.config.ts"
  ]
}
