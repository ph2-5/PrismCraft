{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "rootDir": "src/shared-logic",
    "outDir": "out/shared-logic",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": true,
    "moduleResolution": "node"
  },
  "include": ["src/shared-logic/**/*.ts"],
  "exclude": [
    "src/shared-logic/**/__tests__/**",
    "src/shared-logic/**/*.test.ts"
  ]
}
