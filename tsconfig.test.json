{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "out/types/**/*.ts",
    "out/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "_backup-v2",
    "release",
    "electron",
    "tests",
    "playwright-report",
    "test-results",
    "test-reports",
    "scripts/test-config",
    "scripts/video-test-tool",
    "vitest.config.ts",
    "vitest.config.test-shot.ts",
    "vitest.coverage.config.ts",
    "playwright.config.ts",
    "playwright.electron.config.ts"
  ]
}
