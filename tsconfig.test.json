{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vitest/globals"]
  },
  "include": [
    "src/__tests__/**/*.ts",
    "src/__tests__/**/*.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/__tests__/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "electron/src/**/__tests__/**/*.ts",
    "electron/src/**/*.test.ts",
    "vitest.config.ts",
    "vitest.config.test-shot.ts",
    "vitest.coverage.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
